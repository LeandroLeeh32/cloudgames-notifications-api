<?xml version="1.0" encoding="utf-8" ?>

<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

	<targets>

		<target xsi:type="File"
				name="file"
				fileName="C:\temp\logs\CloudGames.Notifications-${shortdate}.log"
				layout="${longdate} | ${level} | ${logger} | ${message} ${exception}" />

		<target xsi:type="Console"
				name="console"
				layout="${longdate} | ${level} | ${logger} | ${message}" />

	</targets>

	<rules>

		<!-- Bloqueia logs do framework -->
		<logger name="Microsoft.*" maxlevel="Info" final="true" />
		<logger name="MassTransit.*" maxlevel="Info" final="true" />
		<logger name="System.*" maxlevel="Info" final="true" />

		<!-- Bloqueia logs da API -->
		<logger name="CloudGames.Notifications.API.*" maxlevel="Info" final="true" />

		<!-- Bloqueia logs da infraestrutura -->
		<logger name="CloudGames.Notifications.Infrastructure.*" maxlevel="Info" final="true" />

		<!-- Permite somente logs dos UseCases -->
		<logger name="CloudGames.Notifications.Application.UseCases.*"
				minlevel="Info"
				writeTo="console" />

	</rules>


</nlog>